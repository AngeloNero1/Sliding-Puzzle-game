<Window x:Class="SlidingPuzzleGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ana Menü"
        Height="550"
        Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Background="#0B1020">

        <Border Width="360"
                Padding="20"
                Background="#101C3A"
                CornerRadius="15"
                BorderBrush="#E8C46A"
                BorderThickness="2"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel>

                <!-- Başlık -->
                <TextBlock Text="Sliding Puzzle"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#F4F6FF"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- RESİM SEÇ -->
                <Button Content="Arka Plan Resmi Seç"
                        Height="40"
                        Margin="0,0,0,10"
                        Background="#E8C46A"
                        Foreground="Black"
                        Click="SelectImage_Click"/>

                <TextBlock x:Name="TxtImage"
                           Text="Henüz resim seçilmedi"
                           Foreground="#F4F6FF"
                           TextWrapping="Wrap"
                           Margin="0,0,0,15"/>

                <!-- MÜZİK SEÇ -->
                <Button Content="Müzik Seç"
                        Height="40"
                        Margin="0,0,0,10"
                        Background="#E8C46A"
                        Foreground="Black"
                        Click="SelectMusic_Click"/>

                <TextBlock x:Name="TxtMusic"
                           Text="Henüz müzik seçilmedi"
                           Foreground="#F4F6FF"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"/>

                <!-- SES AYARI -->
                <TextBlock Text="Ses Seviyesi"
                           Foreground="White"
                           Margin="0,10,0,5"/>

                <Slider x:Name="VolumeSlider"
                        Minimum="0"
                        Maximum="1"
                        Value="0.5"
                        TickFrequency="0.1"
                        IsSnapToTickEnabled="True"
                        ValueChanged="VolumeSlider_ValueChanged"
                        Margin="0,0,0,10"/>

                <!-- MUTE -->
                <Button x:Name="MuteButton"
                        Content="Sesi Kapat"
                        Height="35"
                        Margin="0,0,0,15"
                        Background="#E8C46A"
                        Foreground="Black"
                        Click="MuteButton_Click"/>

                <!-- BAŞLAT -->
                <Button Content="Oyuna Başla"
                        Height="45"
                        Background="#F2D995"
                        Foreground="Black"
                        FontSize="16"
                        FontWeight="Bold"
                        Click="StartGame_Click"/>

            </StackPanel>

        </Border>

    </Grid>
</Window>